# Qonduit Docker Configuration
# Copy this to .env and customize

# NATS connection URL
QONDUIT_NATS_URL=nats://nats:4222

# API server listen address
QONDUIT_LISTEN_ADDR=0.0.0.0:8080

# Data directory (must match volume mount)
QONDUIT_DATA_DIR=/data

# Processor: catch up from stream start (true) or only new messages (false)
QONDUIT_CATCH_UP=true

# Processor: batch size for message fetching (auto-scales with memory)
QONDUIT_BATCH_SIZE=100

# Logging level (info, debug, warn, error)
RUST_LOG=info
